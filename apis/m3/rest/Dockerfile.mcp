FROM python:3.11-slim

WORKDIR /app

# Install system dependencies
RUN apt-get update && apt-get install -y \
    gcc \
    && rm -rf /var/lib/apt/lists/*

# Copy requirements and install Python dependencies
COPY requirements.txt .
RUN pip install --no-cache-dir -r requirements.txt

# Install MCP and additional dependencies
RUN pip install --no-cache-dir \
    mcp \
    httpx \
    uvicorn[standard]

# Copy application code
COPY . .

# Expose ports
# 8000 for FastAPI
# 8001 for MCP server (if needed for HTTP transport)
EXPOSE 8000 8001

# Set environment variables for database path inside container
ENV HOCKEY_DB_PATH=/app/db/hockey/hockey.sqlite

# Create startup script
RUN echo '#!/bin/bash\n\
set -e\n\
\n\
# Start FastAPI server in the background\n\
echo "Starting FastAPI server..."\n\
uvicorn app:app --host 0.0.0.0 --port 8000 &\n\
FASTAPI_PID=$!\n\
\n\
# Wait for FastAPI to be ready\n\
echo "Waiting for FastAPI to be ready..."\n\
until curl -f http://localhost:8000/health 2>/dev/null; do\n\
    sleep 1\n\
done\n\
echo "FastAPI is ready!"\n\
\n\
# Start MCP server\n\
echo "Starting MCP server..."\n\
export FASTAPI_BASE_URL=http://localhost:8000\n\
python mcp_server.py\n\
\n\
# If MCP server exits, kill FastAPI\n\
kill $FASTAPI_PID\n\
' > /app/start.sh && chmod +x /app/start.sh

CMD ["/app/start.sh"]
